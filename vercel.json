{
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
      {
        "source": "/redirect.html",
        "destination": "/redirect.html"
      }
    ],
    "redirects": [
      {
        "source": "/:path*",
        "has": [
          {
            "type": "host",
            "value": "www.whatsupstowe.io"
          }
        ],
        "destination": "https://whatsupstowe.io/:path*",
        "permanent": true
      }
    ]
  }
  